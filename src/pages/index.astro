---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import avatar from "../assets/snusmumriken-ai.png";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="laat.dev" description="Sigurd Fosseng's developer blog">
  <div class="profile">
    <Image src={avatar} alt="Profile picture" width={160} class="avatar" />
    <div>
      <h1>Sigurd Fosseng</h1>
      <nav class="social">
        <a href="https://github.com/laat">github</a>
        <a href="https://laat.yapping.no">bluesky</a>
        <a href="https://www.linkedin.com/in/sigurdfosseng/">linkedin</a>
      </nav>
    </div>
  </div>
  <section>
    {posts.map((post) => <BlogPostCard post={post} />)}
  </section>
</BaseLayout>

<style>
  .profile {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .profile h1 {
    margin: 0;
    border-bottom: none;
    padding-bottom: 0;
  }
  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
  }
  .profile .social {
    display: flex;
    gap: 1rem;
    margin: 0;
  }
  .social a {
    color: #8b949e;
    text-decoration: none;
  }
  .social a:hover {
    color: #58a6ff;
  }
  section {
    margin: 0;
    padding: 0;
  }
  section :global(article:first-child a) {
    padding-top: 0;
  }
</style>
