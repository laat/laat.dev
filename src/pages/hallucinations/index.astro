---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";

const posts = (await getCollection("hallucinations")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Hallucinations" description="A window into my conversations with AI" noindex>
  <div class="section-header">
    <h1>Hallucinations</h1>
    <p class="subtitle">a window into my conversations with AI</p>
    <p class="warning">These posts are AI-generated and may contain errors, fabrications, or confident nonsense. Read with skepticism.</p>
    <p class="noindex">Not indexed by search engines.</p>
  </div>
  <section>
    {posts.map((post) => <BlogPostCard post={post} collection="hallucinations" />)}
  </section>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 2rem;
  }
  .section-header h1 {
    margin-bottom: 0.25rem;
  }
  .subtitle {
    color: #8b949e;
    font-style: italic;
    margin: 0 0 0.5rem;
  }
  .warning {
    font-size: 0.9rem;
    color: #d29922;
    font-style: italic;
    margin: 0;
  }
  .noindex {
    font-size: 0.8rem;
    color: #484f58;
    font-style: italic;
    margin: 0.25rem 0 0;
  }
  section {
    margin: 0;
    padding: 0;
  }
  section :global(article:first-child a) {
    padding-top: 0;
  }
</style>
