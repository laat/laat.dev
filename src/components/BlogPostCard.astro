---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog"> | CollectionEntry<"hallucinations">;
  collection?: "blog" | "hallucinations";
}

const { post, collection = "blog" } = Astro.props;
const { title, pubDate, description } = post.data;
const formattedDate = pubDate.toLocaleDateString("en-us", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article>
  <a href={`/${collection}/${post.id}/`}>
    <h2>{title}</h2>
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    <p>{description}</p>
  </a>
</article>

<style>
  article a {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1rem 0;
    border-bottom: 1px solid #30363d;
  }
  article a:hover {
    text-decoration: none;
  }
  article a:hover h2 {
    color: #58a6ff;
  }
  article h2 {
    margin: 0 0 0.25rem;
    border-bottom: none;
    padding-bottom: 0;
  }
  article time {
    font-size: 0.85rem;
    color: #8b949e;
  }
  article p {
    margin: 0.5rem 0 0;
    color: #8b949e;
  }
</style>
