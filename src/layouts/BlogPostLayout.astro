---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import avatar from "../assets/snusmumriken-ai.png";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate } = post.data;
const formattedPubDate = pubDate.toLocaleDateString("en-us", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<BaseLayout title={title} description={description}>
  <article>
    <header>
      <h1>{title}</h1>
      <div class="author">
        <Image src={avatar} alt="Sigurd Fosseng" width={56} class="author-avatar" />
        <span>Sigurd Fosseng</span>
      </div>
      <div class="meta">
        <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        {
          updatedDate && (
            <time datetime={updatedDate.toISOString()}>
              (updated{" "}
              {updatedDate.toLocaleDateString("en-us", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })})
            </time>
          )
        }
      </div>
    </header>
    <slot />
  </article>
</BaseLayout>

<style>
  article {
    text-align: justify;
    hyphens: auto;
    text-wrap: pretty;
  }
  article header {
    margin-bottom: 2rem;
    text-align: left;
  }
  article header h1 {
    margin-bottom: 0.25rem;
  }
  .author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #e6edf3;
    margin-bottom: 0.25rem;
  }
  .author-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
  }
  .meta {
    font-size: 0.9rem;
    color: #8b949e;
    display: flex;
    gap: 1rem;
    margin-left: calc(28px + 0.5rem);
  }
</style>
